{
  "name": "korda",
  "version": "0.1.0",
  "private": true,
  "author": "Teolfeu",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Teolfeu/korda.git"
  },
  "bugs": {
    "url": "https://github.com/Teolfeu/korda/issues"
  },
  "homepage": "https://teolfeu.github.io/korda-site/",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "npm@10.9.7",
  "desktopName": "korda",
  "description": "Spatial workbench for orchestrating local AI terminals.",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "app": "npm run build && electron .",
    "package:linux": "npm run build && electron-builder --linux AppImage --publish never",
    "test": "node --test",
    "postinstall": "electron-rebuild -f -w node-pty"
  },
  "dependencies": {
    "node-pty": "1.1.0"
  },
  "devDependencies": {
    "@electron/rebuild": "4.2.0",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@phosphor-icons/react": "2.1.10",
    "@vitejs/plugin-react": "5.0.4",
    "@xterm/addon-fit": "0.11.0",
    "@xterm/xterm": "6.0.0",
    "@xyflow/react": "12.11.2",
    "electron": "41.3.0",
    "electron-builder": "^26.15.3",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "vite": "6.4.3"
  },
  "build": {
    "appId": "app.korda.desktop",
    "productName": "Korda",
    "artifactName": "Korda-${version}-${arch}.${ext}",
    "asar": false,
    "publish": null,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "bin/**/*",
      "assets/**/*",
      "LICENSE",
      "NOTICE",
      "THIRD_PARTY_NOTICES.md",
      "licenses/**/*",
      "package.json"
    ],
    "linux": {
      "target": "AppImage",
      "category": "Development",
      "executableName": "korda",
      "icon": "build/icon.png",
      "executableArgs": [],
      "syncDesktopName": true
    }
  }
}
